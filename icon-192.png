name: Collect news

# 해외대체투자 뉴스를 주기적으로 자동 수집해 news.json 을 갱신합니다.
on:
  schedule:
    - cron: '0 */3 * * *'   # 3시간마다 (UTC 기준)
  workflow_dispatch: {}       # 수동 실행 버튼
  push:
    branches: [ main ]        # 배포 직후 한 번 채우기
    paths: [ 'scripts/collect-news.mjs', '.github/workflows/collect-news.yml' ]

permissions:
  contents: write

concurrency:
  group: collect-news
  cancel-in-progress: false

jobs:
  collect:
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v4
      - uses: actions/setup-node@v4
        with:
          node-version: '20'
      - name: Collect
        run: node scripts/collect-news.mjs
        env:
          # (선택) 무료 Gemini 키를 저장소 Secrets에 GEMINI_API_KEY 로 넣으면
          # 진짜 3줄 요약이 붙습니다. 없으면 추출식 요약으로 동작합니다.
          GEMINI_API_KEY: ${{ secrets.GEMINI_API_KEY }}
      - name: Commit updated feed
        run: |
          git config user.name  "kbgis-bot"
          git config user.email "actions@users.noreply.github.com"
          if ! git diff --quiet news.json; then
            git add news.json
            git commit -m "chore: refresh news feed [skip ci]"
            git push
          else
            echo "No changes."
          fi
